
### CONFIGURATION
SEED = 42
N_REPLICATES = 10  # Number of times to run each benchmark
REPLICATES = list(range(1, N_REPLICATES + 1))
SEEDS = [SEED + REPLICATE for REPLICATE in REPLICATES]

CHR = "chr21"
START = 1
END = 46709982

# CHR = "chr6"
# START = 29941260
# END = 29949572

INPUT_URL = "https://ftp.ncbi.nlm.nih.gov/ReferenceSamples/giab/data/AshkenazimTrio/HG002_NA24385_son/NIST_HiSeq_HG002_Homogeneity-10953946/NHGRI_Illumina300X_AJtrio_novoalign_bams/HG002.GRCh38.300x.bam"
INPUT_PREFIX = "HG002.GRCh38.300x"
INPUT_BAM = f"../../subsample-reads/{INPUT_PREFIX}.bam"

TARGET_BAM = f"{INPUT_PREFIX}-{CHR}-{START}-{END}.bam"

TEMPLATE_URL = "ftp://ftp.sra.ebi.ac.uk/vol1/run/ERR324/ERR3240157/HG00157.final.cram"
TEMPLATE_PREFIX = "HG00157"
TEMPLATE_BAM = f"../../subsample-reads/{TEMPLATE_PREFIX}.bam"
TEMPLATE = f"{TEMPLATE_PREFIX}-{CHR}-{START}-{END}.bed"

# Path to the C samsampleX binary (built from parent directory)
SAMSAMPLEX = "../samsampleX"

### RESOURCES
CPU = 4
MEM_MB = 16384
TIME = "24:00:00"


### RULES
rule all:
    input:
        "results.tsv",
        "results_summary.tsv"

rule build_samsampleX:
    """
    Build samsampleX if not already built
    """
    output:
        binary=SAMSAMPLEX,
    shell:
        """
        cd .. && make
        """

rule download_input_bam:
    """
    Download the input BAM file and index
    """
    params:
        url=INPUT_URL,
    output:
        bam=INPUT_BAM,
    shell:
        """
        wget {params.url} -o {output.bam} && \
        samtools index {output.bam}
        """

rule download_template_bam:
    """
    Download the template CRAM file, convert to BAM and index
    """
    params:
        url=TEMPLATE_URL,
        cram="template.cram",
    output:
        bam=TEMPLATE_BAM,
    shell:
        """
        wget {params.url} -o {params.cram} && \
        samtools view {params.cram} -b -o {output.bam} && \
        rm {params.cram} && \
        samtools index {output.bam}
        """

rule preprocess_input_bam:
    """
    Preprocess the input BAM file to target the specified region
    """
    input:
        bam=INPUT_BAM,
    params:
        chr=CHR,
        start=START,
        end=END,
    output:
        bam=TARGET_BAM,
        index=TARGET_BAM + ".bai",
    resources:
        cpus=CPU,
        mem_mb=MEM_MB,
        time=TIME,
    shell:
        """
        samtools view {input.bam} {params.chr}:{params.start}-{params.end} -b -o {output.bam} && \
        samtools index {output.bam}
        """

rule GATK_HighAccuracy:
    """
    Downsample the input BAM file using GATK HighAccuracy
    """
    input:
        bam=TARGET_BAM,
        index=TARGET_BAM + ".bai",
    params:
        coefficient=0.1,
    wildcard_constraints:
        seed="\d+",
    output:
        bam="gatk-high-accuracy.seed{seed}.bam",
        log="gatk-high-accuracy.seed{seed}.log",
    resources:
        cpus=CPU,
        mem_mb=MEM_MB,
        time=TIME,
    shell:
        """
        env time -o {output.log} -v \
        gatk --java-options "-Xmx16g" DownsampleSam \
        -S HighAccuracy \
        -P {params.coefficient} \
        -R {wildcards.seed} \
        -I {input.bam} \
        -O {output.bam}
        """

