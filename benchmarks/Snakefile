rule samtools:
    """
    Downsample the input BAM file using samtools
    """
    input:
        bam=TARGET_BAM,
        index=TARGET_BAM + ".bai",
    params:
        coefficient=".1",
    wildcard_constraints:
        seed="\d+",
    output:
        bam="samtools.seed{seed}.bam",
        log="samtools.seed{seed}.log",
    resources:
        cpus=CPU,
        mem_mb=MEM_MB,
        time=TIME,
    shell:
        """
        env time -o {output.log} -v \
        samtools view \
        {input.bam} \
        -s {wildcards.seed}{params.coefficient} \
        -b -o {output.bam}
        """

rule sambamba:
    """
    Downsample the input BAM file using sambamba
    """
    input:
        bam=TARGET_BAM,
        index=TARGET_BAM + ".bai",
    params:
        coefficient=".1",
    wildcard_constraints:
        seed="\d+",
    output:
        bam="sambamba.seed{seed}.bam",
        log="sambamba.seed{seed}.log",
    resources:
        cpus=CPU,
        mem_mb=MEM_MB,
        time=TIME,  
    shell:
        """
        env time -o {output.log} -v \
        sambamba view \
        {input.bam} \
        -s {wildcards.seed}{params.coefficient} \
        -o {output.bam}
        """

rule samsampleX_map:
    """
    Map the template BAM file using samsampleX
    """
    input:
        bam=TARGET_BAM,
        index=TARGET_BAM + ".bai",
        binary=SAMSAMPLEX,
    params:
        chr=CHR,
        start=START,
        end=END,
        collapse=1,
    output:
        bed=TEMPLATE,
        log="samsampleX-map.log",
    resources:
        cpus=CPU,
        mem_mb=MEM_MB,
        time=TIME,
    shell:
        """
        env time -o {output.log} -v \
        {input.binary} map \
        --template-bam {TEMPLATE_BAM} \
        --region {params.chr}:{params.start}-{params.end} \
        --out-bed {output.bed} \
        --collapse {params.collapse}
        """

rule samsampleX_sampling:
    """
    Downsample the input BAM file using samsampleX
    Fair comparison: no sorting/indexing, no metrics calculation
    """
    input:
        bam=TARGET_BAM,
        index=TARGET_BAM + ".bai",
        template=TEMPLATE,
        binary=SAMSAMPLEX,
    params:
        mode="mean",
        chr=CHR,
        start=START,
        end=END,
    wildcard_constraints:
        seed="\d+",
    output:
        bam="samsampleX-sample.seed{seed}.bam",
        log="samsampleX-sample.seed{seed}.log",
    resources:
        cpus=CPU,
        mem_mb=MEM_MB,
        time=TIME,
    shell:
        """
        env time -o {output.log} -v \
        {input.binary} sample \
        --source-bam {input.bam} \
        --template-bed {input.template} {input.template} \
        --out-bam {output.bam} \
        --no-sort \
        --no-metrics \
        --region {params.chr}:{params.start}-{params.end} \
        --seed {wildcards.seed} \
        --mode {params.mode}
        """

rule results:
    """
    Collect all individual replicate results into a single TSV
    """
    input:
        gatk_high_accuracy=expand("gatk-high-accuracy.seed{seed}.log", seed=SEEDS),
        gatk_constant_memory=expand("gatk-constant-memory.seed{seed}.log", seed=SEEDS),
        gatk_chained=expand("gatk-chained.seed{seed}.log", seed=SEEDS),
        samtools=expand("samtools.seed{seed}.log", seed=SEEDS),
        sambamba=expand("sambamba.seed{seed}.log", seed=SEEDS),
        samsampleX_map="samsampleX-map.log",
        samsampleX_sample=expand("samsampleX-sample.seed{seed}.log", seed=SEEDS),
    output:
        results="results.tsv"
    resources:
        cpus=CPU,
        mem_mb=MEM_MB,
        time=TIME,
    run:
        import os
        import re
        
        def parse_log(filepath):
            data = {}
            with open(filepath) as f:
                for line in f:
                    line = line.strip()
                    if ': ' in line:
                        key, val = line.split(': ', 1)
                        data[key.strip()] = val.strip()
            return data
        
        results = []
        headers = []
        
        # Parse each tool's replicate logs
        tool_patterns = [
            ("gatk_high_accuracy", "gatk-high-accuracy"),
            ("gatk_constant_memory", "gatk-constant-memory"),
            ("gatk_chained", "gatk-chained"),
            ("samtools", "samtools"),
            ("sambamba", "sambamba"),
            ("samsampleX_sample", "samsampleX-sample"),
        ]
        
        for tool_name, file_prefix in tool_patterns:
            for seed in SEEDS:
                path = f"{file_prefix}.seed{seed}.log"
                data = parse_log(path)
                data["Tool"] = tool_name
                data["Seed"] = str(seed)
                results.append(data)
                if not headers:
                    headers = [k for k in data.keys() if k not in ["Tool", "Seed"]]
        
        # Add samsampleX_map (single run, no replicates)
        map_data = parse_log("samsampleX-map.log")
        map_data["Tool"] = "samsampleX_map"
        map_data["Seed"] = "NA"
        results.append(map_data)
        
        with open(output.results, 'w') as out:
            out.write('\t'.join(['Tool', 'Seed'] + headers) + '\n')
            for data in results:
                row = [data.get("Tool", ""), data.get("Seed", "")] + [data.get(h, '') for h in headers]
                out.write('\t'.join(row) + '\n')


rule results_summary:
    """
    Compute summary statistics (mean, std, min, max) across replicates for each tool
    """
    input:
        results="results.tsv"
    output:
        summary="results_summary.tsv"
    resources:
        cpus=1,
        mem_mb=1024,
        time="01:00:00",
    run:
        import statistics
        import re
        
        def parse_numeric(val):
            """Extract numeric value from string (handles units like '123 kB')"""
            if not val:
                return None
            # Try to extract first numeric part
            match = re.match(r'^([\d.]+)', val.replace(',', ''))
            if match:
                try:
                    return float(match.group(1))
                except ValueError:
                    return None
            return None
        
        # Read results
        with open(input.results) as f:
            header = f.readline().strip().split('\t')
            rows = [line.strip().split('\t') for line in f if line.strip()]
        
        # Group by tool
        tool_data = {}
        for row in rows:
            row_dict = dict(zip(header, row))
            tool = row_dict['Tool']
            if tool not in tool_data:
                tool_data[tool] = []
            tool_data[tool].append(row_dict)
        
        # Compute statistics for numeric columns
        numeric_cols = [h for h in header if h not in ['Tool', 'Seed']]
        
        summary_rows = []
        for tool, reps in tool_data.items():
            summary = {'Tool': tool, 'N_replicates': len(reps)}
            
            for col in numeric_cols:
                values = [parse_numeric(r.get(col, '')) for r in reps]
                values = [v for v in values if v is not None]
                
                if values:
                    summary[f'{col}_mean'] = f"{statistics.mean(values):.4f}"
                    summary[f'{col}_std'] = f"{statistics.stdev(values):.4f}" if len(values) > 1 else "NA"
                    summary[f'{col}_min'] = f"{min(values):.4f}"
                    summary[f'{col}_max'] = f"{max(values):.4f}"
                else:
                    summary[f'{col}_mean'] = "NA"
                    summary[f'{col}_std'] = "NA"
                    summary[f'{col}_min'] = "NA"
                    summary[f'{col}_max'] = "NA"
            
            summary_rows.append(summary)
        
        # Write summary
        if summary_rows:
            summary_headers = list(summary_rows[0].keys())
            with open(output.summary, 'w') as out:
                out.write('\t'.join(summary_headers) + '\n')
                for row in summary_rows:
                    out.write('\t'.join(str(row.get(h, '')) for h in summary_headers) + '\n')


